{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DragonFruit",
  "version": "0.1.2",
  "identifier": "org.openresinalliance.dragonfruit",
  "build": {
    "beforeDevCommand": "node scripts/build-thumbnail-providers.mjs && npm run dev",
    "beforeBuildCommand": "npm run build:tauri && node scripts/build-thumbnail-providers.mjs",
    "devUrl": "http://localhost:3005",
    "frontendDist": "frontend-dist"
  },
  "bundle": {
    "active": true,
    "fileAssociations": [
      {
        "ext": ["voxl"],
        "name": "DragonFruit Scene File",
        "description": "DragonFruit scene",
        "mimeType": "application/vnd.dragonfruit.voxl+json"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "macos-fps": {
      "enabled": true
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "visible": false,
        "backgroundColor": "#0B0F14",
        "title": "DragonFruit",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "maximized": true,
        "resizable": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 10000,
          "y": 10000
        }
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "logging"]
    }
  }
}
