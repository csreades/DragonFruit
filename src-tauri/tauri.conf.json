{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DragonFruit",
  "version": "0.1.2",
  "identifier": "org.openresinalliance.dragonfruit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri",
    "devUrl": "http://localhost:3005",
    "frontendDist": "frontend-dist"
  },
  "bundle": {
    "active": true,
    "fileAssociations": [
      {
        "ext": ["voxl"],
        "name": "DragonFruit Scene File",
        "description": "DragonFruit scene",
        "mimeType": "application/vnd.dragonfruit.voxl+json"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  }
}
