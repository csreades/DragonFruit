msgstr "Reparar"

#. Paraphrase of Doc Brown's line from Back to the Future (1985): "Roads? Where we're going, we don't need roads."
#: src/components/layout/EmptySceneState.tsx:88
msgid "Roads? Where we're printing, we don't need roads."
msgstr "¿Carreteras? Donde imprimimos, no necesitamos carreteras."

#. File type badge on the recent files list. Noun — labels a saved scene file (.voxl, .lys).
#: src/components/layout/EmptySceneState.tsx:643
msgid "Scene"
msgstr "Escena"

#: src/components/layout/EmptySceneState.tsx:572
msgid "Scene Files (.voxl, .lys)"
msgstr "Archivos de escena (.voxl, .lys)"

#: src/components/controls/TransformToolbar.tsx:26
msgid "Sculpt and smooth surface"
msgstr "Esculpir y suavizar la superficie"

#: src/components/controls/TransformToolbar.tsx:21
msgid "Select"
msgstr "Seleccionar"

#: src/components/controls/TransformToolbar.tsx:21
msgid "Select and inspect model"
msgstr "Seleccionar e inspeccionar el modelo"

#: src/components/controls/TransformToolbar.tsx:26
msgid "Smooth"
msgstr "Suavizar"

#: src/components/layout/TopBar.tsx:615
msgid "Support"
msgstr "Soportes"

#: src/app/page.tsx:3535
msgid "Supports"
msgstr "Soportes"

#: src/components/layout/EmptySceneState.tsx:67
msgid "Suspiciously empty in here."
msgstr "Sospechosamente vacío aquí dentro."

#: src/components/layout/EmptySceneState.tsx:60
msgid "The build plate awaits."
msgstr "La placa de impresión te espera."

#: src/components/layout/EmptySceneState.tsx:73
msgid "The build volume misses you."
msgstr "El volumen de impresión te echa de menos."

#: src/components/layout/EmptySceneState.tsx:70
msgid "The resin is ready. Are you?"
msgstr "La resina está lista. ¿Y tú?"

#. Paraphrase of "The spice must flow" from Dune (novel by Frank Herbert, 1965; films 1984 and 2021).
#: src/components/layout/EmptySceneState.tsx:86
msgid "The spice must flow. The resin must cure."
msgstr "La especia debe fluir. La resina debe curar."

#: src/components/layout/EmptySceneState.tsx:68
msgid "This scene is aggressively unoccupied."
msgstr "Esta escena está agresivamente desocupada."

#: src/components/layout/EmptySceneState.tsx:62
msgid "Time to make something real."
msgstr "Es hora de crear algo real."

#. Tip shown below the import buttons. <0> wraps the highlighted label 'Load Mesh'; <1> wraps 'Import Scene'. Keep both placeholders in your translation.
#: src/components/layout/EmptySceneState.tsx:579
msgid "Tip: Start with <0>Load Mesh</0> for clean prints, or <1>Import Scene</1> to continue an existing setup."
msgstr "Consejo: empieza con <0>Cargar malla</0> para impresiones limpias, o <1>Importar escena</1> para continuar con una configuración existente."

#: src/app/page.tsx:3524
msgid "Toggle Curve"
msgstr "Alternar curva"

#: src/components/layout/EmptySceneState.tsx:695
msgid "Unsupported File Type"
msgstr "Tipo de archivo no compatible"

#: src/components/layout/EmptySceneState.tsx:715
msgid "Unsupported format detected. Please drop STL, OBJ, 3MF, VOXL, or LYS files."
msgstr "Formato no compatible. Suelta archivos STL, OBJ, 3MF, VOXL o LYS."

#: src/components/layout/EmptySceneState.tsx:513
msgid "Use without Printer"
msgstr "Usar sin impresora"

#: src/components/layout/EmptySceneState.tsx:90
msgid "Waiting for first layer adhesion... to reality."
msgstr "Esperando la adhesión de la primera capa... a la realidad."

#. Paraphrase of Chief Brody's line from Jaws (1975): "You're gonna need a bigger boat."
#: src/components/layout/EmptySceneState.tsx:82
msgid "We're gonna need a bigger build plate."
msgstr "Vamos a necesitar una placa de impresión más grande."

#: src/components/layout/EmptySceneState.tsx:61
msgid "What are we printing today?"
msgstr "¿Qué imprimimos hoy?"

#. Paraphrase of the Joker's line from The Dark Knight (2008): "Why so serious?"
#: src/components/layout/EmptySceneState.tsx:81
msgid "Why so empty?"
msgstr "¿Por qué tan vacío?"

#. Paraphrase of the Spider-Man motto, originating in Amazing Fantasy #15 (1962): "With great power comes great responsibility."
#: src/components/layout/EmptySceneState.tsx:80
msgid "With great resin comes great responsibility."
msgstr "Una gran resina conlleva una gran responsabilidad."

#. Paraphrase of Gandalf's line from The Lord of the Rings: The Fellowship of the Ring (2001): "You shall not pass!"
#: src/components/layout/EmptySceneState.tsx:78
msgid "You shall not pass... until you load a model."
msgstr "¡No pasarás... hasta que cargues un modelo!"

#: src/components/layout/EmptySceneState.tsx:66
msgid "Your models called. They want to be sliced."
msgstr "Tus modelos han llamado. Quieren ser laminados."

#: src/components/layout/EmptySceneState.tsx:69
msgid "Zero polygons. Infinite potential."
msgstr "Cero polígonos. Potencial infinito."
