#~ msgid "last opened {timeAgo}"
#~ msgstr "abierto {timeAgo}"

#: src/components/layout/EmptySceneState.tsx:652
msgid "last opened just now"
msgstr "abierto ahora mismo"

#: src/components/layout/EmptySceneState.tsx:92
msgid "Layer 0 of 0. Living dangerously."
msgstr "Capa 0 de 0. Viviendo al límite."

#: src/components/layout/EmptySceneState.tsx:550
msgid "Load Mesh"
msgstr "Cargar malla"

#. Shown in place of file size while a recent file is being reopened. Keep it short.
#: src/components/layout/EmptySceneState.tsx:659
msgid "loading…"
msgstr "cargando…"

#. File type badge on the recent files list. Noun — labels a mesh file (.stl, .obj, .3mf).
#: src/components/layout/EmptySceneState.tsx:644
msgid "Mesh"
msgstr "Malla"

#: src/components/layout/EmptySceneState.tsx:553
msgid "Mesh Files (.stl, .obj, .3mf)"
msgstr "Archivos de malla (.stl, .obj, .3mf)"

#: src/components/controls/TransformToolbar.tsx:24
msgid "Mirror"
msgstr "Reflejar"

#: src/components/controls/TransformToolbar.tsx:24
msgid "Mirror across X, Y, or Z"
msgstr "Reflejar en X, Y o Z"

#: src/components/controls/TransformToolbar.tsx:22
msgid "Modify"
msgstr "Modificar"

#: src/components/controls/TransformToolbar.tsx:22
msgid "Move, rotate, and scale"
msgstr "Mover, rotar y escalar"

