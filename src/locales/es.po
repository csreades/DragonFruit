msgstr "Eliminar"

#. Paraphrase of Yoda's line from Star Wars: The Empire Strikes Back (1980): "Do or do not. There is no try."
#: src/components/layout/EmptySceneState.tsx:76
msgid "Do or do not. There is no try... oh wait, just click Load Mesh."
msgstr "Hazlo, o no lo hagas. Pero no lo intentes... espera, sólo haz clic en Cargar malla."

#: src/components/layout/EmptySceneState.tsx:74
msgid "Drag a file in. The platform is judging you."
msgstr "Arrastra un archivo. La plataforma te está juzgando."

#: src/components/layout/EmptySceneState.tsx:695
msgid "Drop supported files"
msgstr "Suelta archivos compatibles"

#: src/app/page.tsx:3535
#: src/components/ui/EditorContextMenu.tsx:85
msgid "Editor"
msgstr "Editor"

#: src/components/ui/EditorContextMenu.tsx:82
msgid "Editor context menu"
msgstr "Menú contextual del editor"

#. Paraphrase of "Elementary, my dear Watson", the line associated with Sherlock Holmes (Arthur Conan Doyle stories; multiple film and TV adaptations).
#: src/components/layout/EmptySceneState.tsx:87
msgid "Elementary, my dear user — load a model."
msgstr "Elemental, querido usuario: carga un modelo."

#: src/components/layout/EmptySceneState.tsx:436
msgid "Empty workspace"
msgstr "Espacio de trabajo vacío"

#: src/components/layout/EmptySceneState.tsx:63
msgid "Every great print starts with an empty scene."
msgstr "Toda gran impresión empieza con una escena vacía."

#: src/components/layout/TopBar.tsx:622
msgid "Export"
msgstr "Exportar"

#: src/components/layout/TopBar.tsx:624
msgid "Finalize and export output"
msgstr "Finalizar y exportar el resultado"

#: src/components/layout/EmptySceneState.tsx:479
msgid "Get started"
msgstr "Empezar"

#: src/components/controls/TransformToolbar.tsx:25
msgid "Hollow"
msgstr "Vaciar"

#. Paraphrase of Walter White's line from Breaking Bad, S04E06 "Cornered": "I am the one who knocks."
#: src/components/layout/EmptySceneState.tsx:79
msgid "I am the one who slices."
msgstr "Yo soy el que lamina."

#. Paraphrase of the Terminator's line from The Terminator (1984): "I'll be back."
#: src/components/layout/EmptySceneState.tsx:84
msgid "I'll be back. (Drop a file and I really will be.)"
msgstr "Volveré. (Suelta un archivo y de verdad que volveré.)"

#. Adaptation of the English proverb "Idle hands are the devil's workshop".
#: src/components/layout/EmptySceneState.tsx:72
msgid "Idle hands do no slicing."
msgstr "Las manos ociosas no laminan."

#. Section header label above the file import buttons. Noun, not imperative verb.
#: src/components/layout/EmptySceneState.tsx:536
msgid "Import"
msgstr "Importación"

#: src/components/layout/EmptySceneState.tsx:569
msgid "Import Scene"
msgstr "Importar escena"

#: src/components/layout/EmptySceneState.tsx:454
msgid "Importing your file…"
msgstr "Importando tu archivo…"

#. Parody of the tagline for Alien (1979): "In space, no one can hear you scream."
#: src/components/layout/EmptySceneState.tsx:77
msgid "In space, no one can hear you slice."
msgstr "En el espacio, nadie puede oírte laminar."

#: src/components/layout/TopBar.tsx:631
msgid "Inspect sliced layers before printing"
msgstr "Inspeccionar las capas laminadas antes de imprimir"

#. Paraphrase of Admiral Ackbar's line from Star Wars: Return of the Jedi (1983): "It's a trap!"
#: src/components/layout/EmptySceneState.tsx:85
msgid "It's a trap! ...just kidding, drop your STL."
msgstr "¡Es una trampa! ...es broma, suelta tu STL."

#: src/components/layout/EmptySceneState.tsx:95
msgid "Join the Open Resin Alliance!"
msgstr "¡Únete a la Open Resin Alliance!"

#: src/components/layout/EmptySceneState.tsx:33
#: src/components/layout/EmptySceneState.tsx:36
#~ msgid "just now"
#~ msgstr "ahora mismo"

#: src/components/layout/EmptySceneState.tsx:516
msgid "Keep going without a printer. You can add one later."
msgstr "Continúa sin impresora. Puedes añadir una más adelante."

#: src/components/layout/EmptySceneState.tsx:653
msgid "last opened {period} ago"
msgstr "abierto hace {period}"

# Shows when a recent file was last accessed. {relativeOpenedAt} is a translated relative time (e.g. "just now", "5m ago"). Place {relativeOpenedAt} wherever the time fits in your language.
