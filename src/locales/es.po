#. Badge shown in the top of the empty workspace when the app is a beta build. Uppercase label.
#: src/components/layout/EmptySceneState.tsx:432
msgid "BETA VERSION"
msgstr "VERSIÓN BETA"

#: src/components/layout/EmptySceneState.tsx:441
msgid "Bring in a mesh or scene to start preparing, analyzing, supporting, and exporting your print."
msgstr "Carga una malla o escena para empezar a preparar, analizar, añadir soportes y exportar tu impresión."

#: src/components/layout/TopBar.tsx:617
msgid "Build and tune supports"
msgstr "Crear y ajustar soportes"

#. Shown in place of file size when the file is in cache but its size is unknown. Adjective/state label.
#: src/components/layout/EmptySceneState.tsx:660
msgid "cached"
msgstr "en caché"

#: src/components/ui/EditorContextMenu.tsx:48
msgid "Copy"
msgstr "Copiar"

#: src/components/layout/EmptySceneState.tsx:381
