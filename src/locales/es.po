msgid "No recent files yet."
msgstr "Todavía no hay archivos recientes."

#: src/components/layout/EmptySceneState.tsx:91
msgid "No supports needed for an empty scene."
msgstr "No se necesitan soportes para una escena vacía."

#. Play on "all men are created equal" from the United States Declaration of Independence (1776).
#: src/components/layout/EmptySceneState.tsx:97
msgid "Not all slicers are created equal. This one's free!"
msgstr "No todos los laminadores son iguales. ¡Este es gratis!"

#: src/components/layout/EmptySceneState.tsx:65
msgid "Nothing to see here. Yet."
msgstr "Nada que ver aquí. Todavía."

#. Toolbar button label. Short for "lay the model flat on a selected face"; keep it terse so the toolbar pill stays narrow.
#: src/components/controls/TransformToolbar.tsx:23
msgid "On-Face"
msgstr "Sobre cara"

#. Paraphrase of Boromir's line from The Lord of the Rings: The Fellowship of the Ring (2001): "One does not simply walk into Mordor."
#: src/components/layout/EmptySceneState.tsx:83
msgid "One does not simply import a mesh... or actually, you just click a button."
msgstr "No se importa una malla sin más... aunque en realidad sí, solo hay que hacer clic en un botón."

#: src/components/layout/EmptySceneState.tsx:497
msgid "Open printer library and add one now."
msgstr "Abre la biblioteca de impresoras y añade una ahora."

#: src/components/controls/TransformToolbar.tsx:23
msgid "Orient flat against plate"
msgstr "Orientar plano sobre la placa"

#: src/components/ui/EditorContextMenu.tsx:49
msgid "Paste"
msgstr "Pegar"

#: src/components/layout/EmptySceneState.tsx:457
msgid "Please hang tight while we prepare your scene."
msgstr "Espera un momento mientras preparamos tu escena."

#: src/components/layout/TopBar.tsx:608
msgid "Prepare"
msgstr "Preparar"

#: src/components/layout/TopBar.tsx:629
msgid "Printing"
msgstr "Imprimir"

#: src/components/layout/EmptySceneState.tsx:59
msgid "Ready for your next adventure?"
msgstr "¿Todo listo para tu próxima aventura?"

#: src/components/layout/EmptySceneState.tsx:591
