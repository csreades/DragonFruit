{
  "name": "dragonfruit",
  "version": "0.1.4",
  "buildChannel": "beta",
  "private": true,
  "scripts": {
    "sync:version": "node scripts/sync-app-version.mjs",
    "postversion": "npm run sync:version",
    "generate:builtin-simple-plugins": "node scripts/generate-builtin-simple-plugins.mjs",
    "generate:plugin-registry": "node scripts/generate-plugin-registry.mjs",
    "check:plugin-allowlist": "node scripts/check-complex-plugin-allowlist.mjs",
    "check:generated-plugin-registry": "node scripts/verify-generated-plugin-registry.mjs",
    "predev": "npm run generate:plugin-registry && npm run generate:builtin-simple-plugins",
    "prebuild": "npm run generate:plugin-registry && npm run generate:builtin-simple-plugins",
    "prebuild:tauri": "npm run generate:plugin-registry && npm run generate:builtin-simple-plugins",
    "pretauri:dev": "npm run sync:version",
    "pretauri:build": "npm run sync:version",
    "pretauri:bundle": "npm run sync:version",
    "pretauri:bundle:windows": "npm run sync:version",
    "pretauri:bundle:linux": "npm run sync:version",
    "pretauri:bundle:macos": "npm run sync:version",
    "pretauri:bundle:macos:arm64": "npm run sync:version",
    "dev": "next dev -p 3005",
    "nas": "next dev -p 3005 --webpack",
    "build": "next build",
    "build:tauri": "next build && node scripts/prepare-tauri-frontend.mjs",
    "start": "next start",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/tauri-build.mjs",
    "tauri:bundle": "node scripts/tauri-bundle-all.mjs",
    "tauri:bundle:windows": "tauri build --target x86_64-pc-windows-msvc --bundles msi,nsis",
    "tauri:bundle:linux": "tauri build --target x86_64-unknown-linux-gnu --bundles deb,rpm,appimage",
    "tauri:bundle:macos": "tauri build --target x86_64-apple-darwin --bundles app,dmg",
    "tauri:bundle:macos:arm64": "tauri build --target aarch64-apple-darwin --bundles app,dmg",
    "macos:thumbnails": "node scripts/macos-thumbnails.mjs",
    "guard:plugin-boundaries": "node scripts/check-plugin-boundaries.mjs",
    "lint": "eslint",
    "test": "node --import tsx --test src/**/__tests__/*.test.ts",
    "test:watch": "node --import tsx --test --watch src/**/__tests__/*.test.ts",
    "bench:support-drag": "node --import tsx scripts/support-drag-perf.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@types/uuid": "^10.0.0",
    "clipper-lib": "^6.4.2",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "fflate": "^0.8.2",
    "ffmpeg-static": "^5.3.0",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "manifold-3d": "^3.4.1",
    "next": "^16.0.7",
    "react": "19.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.0",
    "three": "^0.181.0",
    "three-stdlib": "^2.36.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.8.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.9.4",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.0.7",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch": "^10.2.2"
  }
}
