    <string>VoxlThumbnailExtension</string>
    <key>CFBundleIdentifier</key>
    <string>org.openresinalliance.dragonfruit.voxl-thumbnail-ext</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
