            <string>org.openresinalliance.voxl</string>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>voxl</string>
                </array>
                <key>public.mime-type</key>
                <array>
                    <string>application/x-voxl</string>
                </array>
            </dict>
        </dict>
    </array>

