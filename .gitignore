# package management
/.pnp
/node_modules
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# framework/build outputs
/.next/
/build
/coverage
/out/
**/target/
src-tauri/frontend-dist/**
src-tauri/gen/

