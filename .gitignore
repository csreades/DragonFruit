**/generated*

# environment files (can opt-in for committing if needed)
.env*

# logs/debug
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
*.tsbuildinfo
next-env.d.ts

