# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# package management
/.pnp
/node_modules
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# framework/build outputs
/.next/
/build
/coverage
/dist/
/out/
**/target/
src-tauri/frontend-dist/**
src-tauri/gen/

# generated artifacts
**/generated*

# environment files (can opt-in for committing if needed)
.env*

# logs/debug
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
*.tsbuildinfo
next-env.d.ts

# local/project-specific
/.windsurf/
/.vscode/
/*.code-workspace
/run.bat
/fixtures/
/spec/
/supports_legacy
conversion/
Scratch/
.scratch/
todo_list
tsc_output.txt

# backups
2_Backup/

# platform/deployment
.vercel

src-tauri/gen/
src-tauri/frontend-dist/**
conversion/

**/target/

# misc
*.pem
.DS_Store

# Generated build artifacts that cause rebuild loops
src-tauri/generated_crate_requirements.toml
src-tauri/nsis/
src-tauri/binding.rs
src-tauri/permissions.toml

# compiled native binaries / COM DLLs (built locally, not committed)
src-tauri/windows-resources/*.dll
src-tauri/binaries/dragonfruit-voxl-thumbnailer*
**/build